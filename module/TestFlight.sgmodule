#!name=TestFlight 名额监控
#!desc=定时监控 TestFlight 名额，检测到有名额立即通知
#!category=工具
#!arguments=ids:hmC52rdF,interval:5
#!arguments-desc=ids: TestFlight ID，多个用英文逗号分隔\ninterval: 检查间隔（分钟），默认 5

[Script]
TestFlight名额监控 = type=cron,cronexp="*/{{{interval}}} * * * *",timeout=30,script-path=https://raw.githubusercontent.com/pmjkkk/Surge/main/script/TestFlight.js,argument="{{{ids}}}"
