#!name=TestFlight 名额监控
#!desc=定时监控 TestFlight 名额，检测到有名额立即通知
#!category=工具
#!arguments=ids:请填写你的TestFlight ID,interval:5
#!arguments=ids:请填写你的TestFlight ID,interval:5,log:false
#!arguments-desc=ids: 要监控的 TestFlight ID，多个用英文逗号分隔（如 hmC52rdF,b6X29Sva）\ninterval: 检查间隔（分钟），默认 5 分钟\nlog: 是否开启日志输出（true/false），默认关闭

[Script]
TestFlight名额监控 = type=cron,cronexp="*/{{{interval}}} * * * *",timeout=30,script-path=https://raw.githubusercontent.com/pmjkkk/Surge/main/script/TestFlight.js,argument="ids={{{ids}}}&log={{{log}}}"
