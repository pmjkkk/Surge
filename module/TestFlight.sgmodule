#!name=TestFlight 名额监控
#!desc=定时监控 TestFlight 名额，仅在「满→有名额」时通知一次。在下方参数填入要监控的 ID（多个用英文逗号分隔，可加 #备注名）
#!category=工具
#!arguments=ids:hmC52rdF#示例APP,b6X29Sva&interval:5
#!arguments-desc=ids: 要监控的 TestFlight ID，多个用英文逗号分隔，可用「ID#备注」格式\ninterval: 检查间隔（分钟），默认 5

[Script]
TestFlight名额监控 = type=cron,cronexp=*/%interval% * * * *,timeout=30,script-path=https://raw.githubusercontent.com/pmjkkk/Surge/main/script/TestFlight.js,argument=%ids%
